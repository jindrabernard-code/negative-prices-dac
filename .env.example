# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# The .env file must NOT be committed to version control.
#
#   cp .env.example .env

# ── ENTSO-E Transparency Platform ─────────────────────────────────────────────
# How to get:
#   1. Register (free) at https://transparency.entsoe.eu
#   2. Send an email to transparency@entsoe.eu
#        Subject: Restful API access
#        Body:    the email address you registered with
#      (approval takes up to 3 working days)
#   3. After the confirmation email: log in → My Account Settings
#      → Web API Security Token → Generate
#   4. Paste the token below.
ENTSOE_API_KEY=your_entso_e_token_here

# ── Copernicus Climate Data Store (ERA5 weather) ──────────────────────────────
# How to get (new CDS API, 2024+):
#   1. Register (free) at https://cds.climate.copernicus.eu
#   2. Accept the ERA5 dataset licence on the dataset page:
#      https://cds.climate.copernicus.eu/datasets/reanalysis-era5-single-levels
#   3. Go to https://cds.climate.copernicus.eu/profile
#   4. Copy your Personal Access Token (a UUID) and paste it below.
CDS_API_KEY=your_personal_access_token_here
CDS_API_URL=https://cds.climate.copernicus.eu/api
